# Copy to .env.local and fill in. Also set these in the Vercel project
# Environment Variables for production. .env.local is gitignored.

# --- Ask Jethro + symptom parsing (Gemini) -------------------------------
# Used by the Ask Jethro assistant and ONLY for parsing free-text symptoms
# into structured input for the symptom checker (never for medical logic).
# Get a long-lived key at https://aistudio.google.com/app/apikey (starts with AIza...)
GEMINI_API_KEY=

# --- Isabel Symptom Checker (the symptom checker's only medical source) ---
# The "akinator" symptom checker calls Isabel server-side for all medical
# data. Until both are set AND the placeholder endpoints in lib/isabelApi.ts
# are replaced with Isabel's real paths, the checker shows a clean
# "temporarily unavailable" state (it never falls back to local data).
ISABEL_API_BASE_URL=
ISABEL_API_KEY=

# --- Feature flag --------------------------------------------------------
# Set to "false" to hide the symptom checker entirely (trigger, modal, and
# API route all respect it). Any other value (or unset) = enabled.
NEXT_PUBLIC_MEDICAL_AKINATOR_ENABLED=true
