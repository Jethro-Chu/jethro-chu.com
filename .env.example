# Ask Jethro (Gemini) — copy to .env.local and set your key.
# Also set this in the Vercel project Environment Variables for production.
# Get a long-lived key at https://aistudio.google.com/app/apikey (starts with AIza...)
GEMINI_API_KEY=

# Medical Akinator learning store (optional) — Vercel KV / Upstash Redis.
# When the engine is stumped, it saves the condition so it recognizes it next
# time. WITHOUT these the feature still works but only remembers within a single
# warm serverless instance (not durable). To persist for real: in Vercel →
# Storage → Create Database → KV (Upstash); the two vars below are injected
# into the project automatically. Pull them locally with `vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
